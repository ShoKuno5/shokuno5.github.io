---
import Layout from '../layouts/Layout.astro';
import { SITE, CONTACT_LINKS } from '../config/site.js';
import ContactLink from '../components/ContactLink.astro';
---

<Layout title={`${SITE.name}`} description={SITE.tagline} hideFooter>
  <section class="landing-hero">
    <h1 class="landing-hero__name">{SITE.name}</h1>
    <p class="landing-hero__subtitle">Building machines that see and generate in 3D.</p>
    <p class="landing-hero__subtitle">PhD student at the University of Tokyo.</p>
    <nav class="landing-hero__links">
      {CONTACT_LINKS.map((contact) => (
        <ContactLink contact={contact} className="icon-link" />
      ))}
    </nav>
  </section>

  <section class="landing-section">
    <h2>Research</h2>
    <p>
      3D object generation, world models.
    </p>
  </section>
</Layout>
