---
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../config/site.js';
---

<Layout title="Research - Sho Kuno" description="Research themes, publications, and academic background.">
  <header class="page-header">
    <h1>Research</h1>
  </header>

  <section class="research-section">
    <h2>Current Focus</h2>
    <p>
      I am a PhD student at the University of Tokyo, working on 3D object generation
      within a world models research team. My research explores how generative models
      can learn structured, three-dimensional representations of the world.
    </p>
    <p>Specific interests include:</p>
    <ul>
      <li>3D object generation (diffusion-based, feed-forward, 3D Gaussian splatting)</li>
      <li>World models and video generation</li>
      <li>Geometric deep learning on non-Euclidean data</li>
      <li>Flow matching and diffusion models with symmetry structure</li>
    </ul>
  </section>

  <section class="research-section">
    <h2>Background</h2>
    <ul>
      <li><strong>Master's thesis:</strong> Generative Modeling of Graph-Structured Data via Latent Flow Matching</li>
      <li><strong>Industry internship:</strong> Graph-Based Approaches on Anime Frame Interpolation</li>
      <li><strong>Bachelor's thesis:</strong> Time-series prediction of a dynamical system via Reservoir Computing</li>
    </ul>
  </section>

  <section class="research-section">
    <h2>Publications</h2>
    <p>
      <a href={SITE.contact.scholar} target="_blank" rel="noopener">Google Scholar</a>
      &nbsp;&middot;&nbsp;
      <a href={SITE.contact.cv}>Download CV (PDF)</a>
    </p>
  </section>

  <section class="research-section">
    <h2>Collaborate</h2>
    <p>
      If you want to collaborate or discuss related ideas, feel free to reach out via
      <a href={`mailto:${SITE.contact.email}`}>email</a>.
    </p>
  </section>
</Layout>
